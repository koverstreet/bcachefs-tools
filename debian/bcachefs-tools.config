#!/bin/sh
# Debconf preconfigure: if Secure Boot is enabled, offer to enroll the
# bcachefs module-signing CA into the MOK store. The actual enrollment is
# staged by the postinst; this only gathers consent and a one-time password.
#
# Everything here fails open: if mokutil is missing, efivars aren't present
# (chroot / container / non-EFI), or the frontend is noninteractive, we ask
# nothing and let the install proceed untouched.
set -e

. /usr/share/debconf/confmodule

CERT=/usr/share/bcachefs-tools/bcachefs-signing-ca.der

secureboot_enabled() {
	command -v mokutil >/dev/null 2>&1 || return 1
	mokutil --sb-state 2>/dev/null | grep -qi "SecureBoot enabled"
}

# On first install the cert may not be unpacked yet, so this can't always run;
# the postinst repeats the check once the file is present.
already_enrolled() {
	[ -f "$CERT" ] && mokutil --test-key "$CERT" 2>/dev/null | grep -qi "already enrolled"
}

secureboot_enabled || exit 0
already_enrolled && exit 0

db_input high bcachefs-tools/enroll-mok || true
db_go || true

db_get bcachefs-tools/enroll-mok
[ "$RET" = "true" ] || exit 0

while :; do
	db_set bcachefs-tools/mok-password ""
	db_set bcachefs-tools/mok-password-again ""
	db_fset bcachefs-tools/mok-password seen false
	db_fset bcachefs-tools/mok-password-again seen false

	db_input high bcachefs-tools/mok-password || true
	# If the second prompt can't be shown (noninteractive / priority too low),
	# we can't collect a password — disable enrollment and stop, rather than
	# spinning forever.
	rc=0
	db_input high bcachefs-tools/mok-password-again || rc=$?
	db_go || true
	if [ "$rc" = "30" ]; then
		db_set bcachefs-tools/enroll-mok false
		break
	fi

	db_get bcachefs-tools/mok-password;      pw1="$RET"
	db_get bcachefs-tools/mok-password-again; pw2="$RET"
	if [ -n "$pw1" ] && [ "$pw1" = "$pw2" ]; then
		break
	fi

	db_input high bcachefs-tools/mok-password-mismatch || true
	db_go || true
done
